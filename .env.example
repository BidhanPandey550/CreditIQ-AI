# ── Environment configuration (copy to .env). NEVER commit real secrets. ──

# --- Database ---
POSTGRES_USER=creditiq
POSTGRES_PASSWORD=creditiq_dev_password
POSTGRES_DB=creditiq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# App connects as a NON-superuser role so Row-Level Security is actually enforced.
DATABASE_URL=postgresql+psycopg://creditiq_app:creditiq_app_password@postgres:5432/creditiq

# --- Redis (cache / rate-limit / future queues) ---
REDIS_URL=redis://redis:6379/0
AUTH_LOGIN_RATE_LIMIT=10
AUTH_REFRESH_RATE_LIMIT=30
AUTH_MFA_RATE_LIMIT=10
AI_ANALYSIS_RATE_LIMIT=20
RATE_LIMIT_WINDOW_SECONDS=60

# --- Security ---
# Generate a strong secret in real deployments: `openssl rand -hex 32`
JWT_SECRET_KEY=dev-only-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=creditiq-backend
JWT_AUDIENCE=creditiq-platform
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=creditiq_refresh
# Development compatibility only. Production configuration must set this to false.
EXPOSE_REFRESH_TOKEN_IN_BODY=true
# Development-only Fernet key. Generate independently for production:
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
MFA_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
MFA_ISSUER=CreditIQ AI
MFA_CHALLENGE_EXPIRE_MINUTES=5

# --- ML engine ---
ML_ENGINE_URL=http://ml-engine:8001
ML_ENGINE_TIMEOUT_SECONDS=5
ML_SERVING_ENVIRONMENT=development
# Required when ML_SERVING_ENVIRONMENT=production.
# ML_SERVING_REGISTRY_PATH=/run/creditiq/registry.json
ML_SERVING_MODEL_NAME=credit-risk
ML_SERVING_MODEL_ENVIRONMENT=production
# High/critical alerts block approval until an analyst dismisses them.
FRAUD_APPROVAL_BLOCKING_SEVERITIES=high,critical

# --- Loan servicing ---
# Product-level annual rates override this institutional fallback.
SERVICING_DEFAULT_ANNUAL_INTEREST_RATE=0
SERVICING_FIRST_DUE_DAYS=30
SERVICING_GRACE_DAYS=0
SERVICING_PAR_THRESHOLD_DAYS=1,30,60,90

# --- Private financial documents ---
DOCUMENT_STORAGE_ROOT=/var/lib/creditiq/documents
DOCUMENT_MAX_BYTES=10485760
DOCUMENT_ALLOWED_CONTENT_TYPES=application/pdf,image/jpeg,image/png
# Production must set true and provide CLAMAV_HOST.
DOCUMENT_SCAN_REQUIRED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=10
DOCUMENT_UPLOAD_RATE_LIMIT=10

# --- App ---
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SEED_ON_STARTUP=true
AUTO_MIGRATE_ON_STARTUP=true
LOG_LEVEL=INFO

# --- Frontend ---
VITE_API_BASE_URL=/api/v1
